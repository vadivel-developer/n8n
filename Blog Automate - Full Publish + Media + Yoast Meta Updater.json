      "parameters": {
        "jsCode": "const original = $('Prepare Post Data1').first().json;\nconst results = Array.isArray($json) ? $json : [];\nconst fileName = String(original.imageFileName || '').toLowerCase();\nconst stem = String(original.imageSearchTerm || '').toLowerCase();\n\nlet matched = null;\nif (results.length) {\n  matched = results.find(item => {\n    const src = String(item.source_url || '').toLowerCase();\n    return (fileName && src.includes(fileName)) || (stem && src.includes(stem));\n  }) || null;\n}\n\nreturn [{\n  json: {\n    ...original,\n    featuredMediaId: matched ? matched.id : '',\n    needUpload: matched ? false : true\n  }\n}];"
