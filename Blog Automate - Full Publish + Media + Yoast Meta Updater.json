    {
      "parameters": {
        "jsCode": "function toIdArray(value) {\n  if (!value) return [];\n  return String(value)\n    .split(',')\n    .map(v => v.trim())\n    .filter(Boolean)\n    .map(v => Number(v))\n    .filter(v => !Number.isNaN(v));\n}\n\nfunction styleContent(html) {\n  if (!html) return '';\n  let out = String(html);\n  out = out.replace(/<h2(\\s[^>]*)?>/gi, '<h2 class=\"automate-h2\">');\n  out = out.replace(/<h3(\\s[^>]*)?>/gi, '<h3 class=\"automate-h3\">');\n  out = out.replace(/<p(\\s[^>]*)?>/gi, '<p class=\"automate para\">');\n  return out;\n}\n\nconst h1 = ($json['H1'] || '').trim();\nconst bodyHtml = ($json['Body HTML'] || '').trim();\nconst combined = h1 ? `<h1>${h1}</h1>\\n${bodyHtml}` : bodyHtml;\n\nconst featureImageUrl = ($json['Feature Image'] || '').trim();\nconst imageFileName = featureImageUrl ? featureImageUrl.split('/').pop().split('?')[0] : '';\nconst imageSearchTerm = imageFileName ? imageFileName.replace(/\\.[^.]+$/, '') : '';\n\nreturn [{\n  json: {\n    row_number: String($json['row_number'] || '').trim(),\n    title: ($json['Title'] || '').trim(),\n    slug: ($json['Slug'] || '').trim(),\n    excerpt: ($json['Excerpt'] || '').trim(),\n    content: styleContent(combined),\n    postStatus: String($json['Post Status'] || 'draft').trim().toLowerCase(),\n    categoryIds: toIdArray($json['Category']),\n    tagIds: toIdArray($json['Tags']),\n    featureImageUrl,\n    imageFileName,\n    imageSearchTerm,\n    existingPostId: String($json['WordPress Post ID'] || '').trim(),\n    seoTitle: ($json['SEO Title'] || '').trim(),\n    metaDescription: ($json['Meta Description'] || '').trim(),\n    canonicalUrl: ($json['Canonical URL'] || '').trim(),\n    socialTitle: ($json['Social Title'] || '').trim(),\n    socialDescription: ($json['Social Description'] || '').trim(),\n    focusKeyword: ($json['Focus Keyword'] || '').trim()\n  }\n}];"
      },
